<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SaveGuard.ViewModels"
        xmlns:m="using:SaveGuard.Models"
        xmlns:v="using:SaveGuard.Views"
        x:Class="SaveGuard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="760"
        MinWidth="820" MinHeight="680"
        Title="SaveGuard"
        Background="{StaticResource InkBaseBrush}">

    <Window.Resources>
        <v:LabelToBrushConverter x:Key="LabelBrush" />
        <v:WatchLabelToBrushConverter x:Key="WatchBrush" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left rail: user-resizable by dragging the splitter, clamped so it
                 can't collapse away or swallow the editor. -->
            <ColumnDefinition Width="252" MinWidth="200" MaxWidth="460" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="500" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT RAIL: profiles ============ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="18,20,18,18">

                <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Center"
                                Background="{StaticResource GuardGoldBrush}" />
                        <TextBlock Text="SaveGuard" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="Versioned backups for any game's saves"
                               FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="18,0,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource InkBaseBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="4">
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:GameProfile">
                                <StackPanel Spacing="2" Margin="2,4">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Text="{Binding WatchPath}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Button Grid.Row="2" Classes="ghost" Margin="0,14,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Command="{Binding AddProfileCommand}"
                        Content="+  Add a game" />
            </Grid>
        </Border>

        <!-- draggable divider between the rail and the editor -->
        <GridSplitter Grid.Column="1" Width="6"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                      Background="Transparent"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- ============ RIGHT: editor + snapshots ============ -->
        <Grid Grid.Column="2" RowDefinitions="*,Auto" Margin="0">
            <!-- The backups card is docked to the bottom so its action buttons are
                 always visible; the editor fills the remaining space and scrolls
                 inside it. A DockPanel (rather than a star-split Grid) lets the
                 editor take exactly the leftover height instead of an arbitrary
                 fraction, so the two regions never overlap. The editor ScrollViewer
                 must sit in a width-bounded slot (the DockPanel fill) or it measures
                 its content unbounded and the Browse buttons spill off-screen. -->
            <DockPanel Grid.Row="0" IsVisible="{Binding HasProfile}" LastChildFill="True">

            <!-- backups card: docked bottom; list flexes (bounded), buttons pinned -->
            <Border DockPanel.Dock="Bottom" Classes="card" Margin="24,6,24,12">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <TextBlock Grid.Column="0" Classes="eyebrow" Text="BACKUPS"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="ghost" Content="Open folder"
                                    Command="{Binding OpenBackupFolderCommand}" />
                            <Button Classes="primary" Content="Back up now"
                                    Command="{Binding BackupNowCommand}"
                                    IsEnabled="{Binding !Busy}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" MinHeight="84" MaxHeight="150">
                        <Border Grid.Column="0" Background="{StaticResource InkBaseBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="2">
                            <ListBox ItemsSource="{Binding Snapshots}"
                                     SelectedItem="{Binding SelectedSnapshot}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:Snapshot">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,5">
                                            <Border Grid.Column="0" Width="7" CornerRadius="3"
                                                    Margin="0,1,12,1"
                                                    Background="{Binding Label, Converter={StaticResource LabelBrush}}" />
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{Binding TakenAtDisplay}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SubLine}"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- save preview: shown only when a matching image exists -->
                        <Border Grid.Column="1" Width="200" Margin="10,0,0,0"
                                IsVisible="{Binding HasPreviewImage}"
                                Background="{StaticResource InkBaseBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="4">
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Classes="ghost" Content="Open this backup"
                                Command="{Binding OpenSnapshotFolderCommand}"
                                IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button Classes="danger" Content="Delete"
                                Command="{Binding DeleteSnapshotCommand}"
                                IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button Classes="primary" Content="Restore this backup"
                                Command="{Binding RestoreSelectedCommand}"
                                IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="EditorScroller" Padding="0"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <!-- Pin the content width to the scroller's actual width. Avalonia 12's
                     ScrollViewer measures content with unbounded width even when
                     horizontal scrolling is Disabled, so a long path TextBox would
                     otherwise stretch the layout and push the Browse buttons off the
                     right edge at narrow window widths. Capping the wrapper at the
                     scroller's Bounds.Width forces the TextBoxes to clip instead. -->
                <Border Padding="24,22,24,6" HorizontalAlignment="Stretch"
                        MaxWidth="{Binding #EditorScroller.Bounds.Width}">
                <StackPanel Spacing="18">

                    <!-- header: name + watch state -->
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBox Grid.Column="0" Text="{Binding SelectedProfile.Name}"
                                 FontSize="20" FontWeight="Bold"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 Foreground="{StaticResource TextPrimaryBrush}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{Binding WatchStateLabel, Converter={StaticResource WatchBrush}}" />
                            <TextBlock Text="{Binding WatchStateLabel}"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- folders card -->
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="eyebrow" Text="FOLDERS" />

                            <StackPanel Spacing="4">
                                <TextBlock Classes="field" Text="Save folder to watch" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding SelectedProfile.WatchPath}"
                                             Watermark="e.g. the game's Savegames folder" />
                                    <Button Grid.Column="1" Classes="ghost" Content="Browse…"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseWatchCommand}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="field" Text="Store backups in  (must be outside the save folder)" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding SelectedProfile.BackupRoot}"
                                             Watermark="where snapshots are written" />
                                    <Button Grid.Column="1" Classes="ghost" Content="Browse…"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseBackupCommand}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- options card -->
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="eyebrow" Text="HOW IT BACKS UP" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="field" Text="Keep this many backups" />
                                    <NumericUpDown Value="{Binding SelectedProfile.MaxSnapshots}"
                                                   Minimum="1" Maximum="500" Increment="1"
                                                   FormatString="0" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="20,0,0,0">
                                    <TextBlock Classes="field" Text="Wait after last write (ms)" />
                                    <NumericUpDown Value="{Binding SelectedProfile.DebounceMs}"
                                                   Minimum="200" Maximum="15000" Increment="250"
                                                   FormatString="0" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,14,0,0">
                                    <TextBlock Classes="field" Text="Only trigger on these types (optional)" />
                                    <TextBox Text="{Binding SelectedProfile.TriggerExtensions}"
                                             Watermark=".lsv, .sav   (blank = any change)" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="10" VerticalAlignment="Bottom" Margin="20,14,0,0">
                                    <CheckBox IsChecked="{Binding SelectedProfile.Recursive}"
                                              Content="Include subfolders"
                                              Foreground="{StaticResource TextPrimaryBrush}" />
                                    <CheckBox IsChecked="{Binding SelectedProfile.AutoWatch}"
                                              Content="Auto-backup whenever the game saves"
                                              Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4" Margin="0,14,0,0">
                                    <TextBlock Classes="field" Text="Show preview image of these types (optional)" />
                                    <TextBox Text="{Binding SelectedProfile.ImageExtensions}"
                                             Watermark=".png, .webp   (blank = no preview)" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Classes="danger" Content="Delete game"
                                        Command="{Binding DeleteProfileCommand}" />
                                <Button Classes="primary" Content="Save settings"
                                        Command="{Binding SaveProfileCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </Border>
            </ScrollViewer>
            </DockPanel>

            <!-- empty state -->
            <StackPanel Grid.Row="0" IsVisible="{Binding !HasProfile}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="No game selected" FontSize="16"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Add a game to start protecting its saves."
                           Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- status bar -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0"
                    Padding="20,9">
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>
