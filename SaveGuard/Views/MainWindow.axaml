<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SaveGuard.ViewModels"
        xmlns:m="using:SaveGuard.Models"
        xmlns:v="using:SaveGuard.Views"
        xmlns:loc="using:SaveGuard.Views"
        x:Class="SaveGuard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="760"
        MinWidth="820" MinHeight="680"
        Title="SaveGuard"
        Icon="/Assets/saveguard.ico"
        Background="{StaticResource InkBaseBrush}">

    <Window.Resources>
        <v:LabelToBrushConverter x:Key="LabelBrush" />
        <v:WatchLabelToBrushConverter x:Key="WatchBrush" />
        <v:PathToBitmapConverter x:Key="IconBitmap" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left rail: user-resizable by dragging the splitter, clamped so it
                 can't collapse away or swallow the editor. -->
            <ColumnDefinition Width="252" MinWidth="200" MaxWidth="460" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="500" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT RAIL: profiles ============ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="18,20,18,18">

                <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Center"
                                Background="{StaticResource GuardGoldBrush}" />
                        <TextBlock Text="SaveGuard" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="{loc:Loc App.Tagline}"
                               FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="18,0,0,0" />
                    <Button Classes="ghost" Margin="0,14,0,0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding AddProfileCommand}"
                            Content="{loc:Loc Rail.AddGame}" />
                    <Button Classes="ghost" Margin="0,8,0,0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding ImportFromSteamCommand}"
                            Content="{loc:Loc Rail.ImportSteam}" />
                    <TextBox Text="{Binding ProfileFilter}" Margin="0,12,0,0"
                             PlaceholderText="{loc:Loc Rail.SearchGames}" />
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource InkBaseBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="4">
                    <ListBox ItemsSource="{Binding FilteredProfiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:GameProfile">
                                <Grid ColumnDefinitions="Auto,*" Margin="2,4">
                                    <Panel Grid.Column="0" Width="30" Height="30" Margin="0,0,9,0"
                                           VerticalAlignment="Center">
                                        <Border CornerRadius="7" Background="{StaticResource SurfaceRaisedBrush}"
                                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <TextBlock Text="{Binding Initial}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="7" ClipToBounds="True">
                                            <Image Source="{Binding IconPath, Converter={StaticResource IconBitmap}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Panel>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding WatchPath}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Button Grid.Row="2" Classes="ghost" Margin="0,14,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Command="{Binding SettingsCommand}"
                        Content="{loc:Loc Rail.Settings}" />
            </Grid>
        </Border>

        <!-- draggable divider between the rail and the editor -->
        <GridSplitter Grid.Column="1" Width="6"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                      Background="Transparent"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- ============ RIGHT: editor + snapshots ============ -->
        <Grid Grid.Column="2" RowDefinitions="*,Auto" Margin="0">
            <!-- Right panel is an accordion: each section is a collapsible Expander
                 stacked top-down in one scroller, so the sections stay together (no
                 big gap on tall/fullscreen windows) and any can be collapsed to
                 reclaim vertical space. The width-capped wrapper stops a long path
                 TextBox from stretching the layout — Avalonia 12's ScrollViewer
                 measures content unbounded horizontally even with scrolling Disabled. -->
            <ScrollViewer x:Name="EditorScroller" Grid.Row="0" Padding="0"
                          IsVisible="{Binding HasProfile}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Padding="24,22,24,16" HorizontalAlignment="Stretch"
                        MaxWidth="{Binding #EditorScroller.Bounds.Width}">
                <StackPanel Spacing="14">

                    <!-- header: name + watch state + delete (a profile-level action,
                         kept at the very top, away from the backup settings) -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                        <!-- game icon: click the avatar to choose an image, the ✕ badge (shown on hover) to clear -->
                        <Grid Grid.Column="0" Classes="iconcell" Width="44" Height="44" Margin="0,0,14,0" VerticalAlignment="Center">
                            <Button Classes="avatar" Command="{Binding BrowseIconCommand}"
                                    ToolTip.Tip="{loc:Loc Icon.Choose}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Panel>
                                    <Border CornerRadius="9" Background="{StaticResource SurfaceRaisedBrush}"
                                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding SelectedProfile.Initial}" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="9" ClipToBounds="True">
                                        <Image Source="{Binding SelectedProfile.IconPath, Converter={StaticResource IconBitmap}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </Panel>
                            </Button>
                            <Button Classes="badge" Content="✕" Command="{Binding ClearIconCommand}"
                                    IsVisible="{Binding SelectedProfile.HasIcon}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    ToolTip.Tip="{loc:Loc Icon.Clear}" />
                        </Grid>
                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.Name}"
                                 FontSize="20" FontWeight="Bold"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource TextPrimaryBrush}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{Binding WatchStateLabel, Converter={StaticResource WatchBrush}}" />
                            <TextBlock Text="{Binding WatchStateLabel}"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="3" Classes="danger" Content="{loc:Loc Header.DeleteGame}"
                                Margin="14,0,0,0" VerticalAlignment="Center"
                                Command="{Binding DeleteProfileCommand}" />
                    </Grid>

                    <!-- FOLDERS -->
                    <Expander Classes="section" IsExpanded="{Binding FoldersExpanded, Mode=TwoWay}">
                        <Expander.Header><TextBlock Classes="eyebrow" Text="{loc:Loc Section.Folders}" /></Expander.Header>
                        <StackPanel Spacing="14" Margin="2,4,2,2">

                            <StackPanel Spacing="4">
                                <TextBlock Classes="field" Text="{loc:Loc Folders.WatchLabel}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding SelectedProfile.WatchPath}"
                                             PlaceholderText="{loc:Loc Folders.WatchWatermark}" />
                                    <Button Grid.Column="1" Classes="ghost" Content="{loc:Loc Common.Browse}"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseWatchCommand}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="field" Text="{loc:Loc Folders.BackupLabel}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding SelectedProfile.BackupRoot}"
                                             PlaceholderText="{loc:Loc Folders.BackupWatermark}" />
                                    <Button Grid.Column="1" Classes="ghost" Content="{loc:Loc Common.Browse}"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseBackupCommand}" />
                                </Grid>
                                <TextBlock Classes="field" Text="{loc:Loc Folders.BackupHint}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding EffectiveBackupDir}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="10.5"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding EffectiveBackupDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- HOW IT BACKS UP -->
                    <Expander Classes="section" IsExpanded="{Binding OptionsExpanded, Mode=TwoWay}">
                        <Expander.Header><TextBlock Classes="eyebrow" Text="{loc:Loc Section.HowItBacksUp}" /></Expander.Header>
                        <StackPanel Spacing="14" Margin="2,4,2,2">

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="field" Text="{loc:Loc How.KeepCount}" />
                                    <NumericUpDown Value="{Binding SelectedProfile.MaxSnapshots}"
                                                   Minimum="1" Maximum="500" Increment="1"
                                                   FormatString="0" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="20,0,0,0">
                                    <TextBlock Classes="field" Text="{loc:Loc How.WaitMs}" />
                                    <NumericUpDown Value="{Binding SelectedProfile.DebounceMs}"
                                                   Minimum="200" Maximum="15000" Increment="250"
                                                   FormatString="0" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,14,0,0">
                                    <TextBlock Classes="field" Text="{loc:Loc How.TriggerTypes}" />
                                    <TextBox Text="{Binding SelectedProfile.TriggerExtensions}"
                                             PlaceholderText="{loc:Loc How.TriggerWatermark}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="10" VerticalAlignment="Bottom" Margin="20,14,0,0">
                                    <CheckBox IsChecked="{Binding SelectedProfile.Recursive}"
                                              Content="{loc:Loc How.IncludeSubfolders}"
                                              Foreground="{StaticResource TextPrimaryBrush}" />
                                    <CheckBox IsChecked="{Binding SelectedProfile.AutoWatch}"
                                              Content="{loc:Loc How.AutoBackup}"
                                              Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4" Margin="0,14,0,0">
                                    <TextBlock Classes="field" Text="{loc:Loc How.ImageTypes}" />
                                    <TextBox Text="{Binding SelectedProfile.ImageExtensions}"
                                             PlaceholderText="{loc:Loc How.ImageWatermark}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="field" VerticalAlignment="Center"
                                               Text="{loc:Loc How.CompanionLabel}" />
                                    <Button Grid.Column="1" Classes="ghost" Padding="11,5" FontSize="11"
                                            Content="{loc:Loc How.AddFile}"
                                            Command="{Binding AddCompanionFileCommand}" />
                                </Grid>
                                <TextBox Text="{Binding SelectedProfile.CompanionFiles}"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         MinHeight="58" MaxHeight="120"
                                         VerticalContentAlignment="Top"
                                         PlaceholderText="{loc:Loc How.CompanionWatermark}" />
                                <TextBlock Classes="field" Text="{loc:Loc How.CompanionHint}" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="field" VerticalAlignment="Center"
                                               Text="{loc:Loc How.ExcludeLabel}" />
                                    <Button Grid.Column="1" Classes="ghost" Padding="11,5" FontSize="11"
                                            Content="{loc:Loc How.AddFile}"
                                            Command="{Binding AddExcludeFileCommand}" />
                                </Grid>
                                <TextBox Text="{Binding SelectedProfile.ExcludePatterns}"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         MinHeight="58" MaxHeight="120"
                                         VerticalContentAlignment="Top"
                                         PlaceholderText="{loc:Loc How.ExcludeWatermark}" />
                                <TextBlock Classes="field" Text="{loc:Loc How.ExcludeHint}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- BACKUPS -->
                    <Expander Classes="section" IsExpanded="{Binding BackupsExpanded, Mode=TwoWay}">
                        <Expander.Header><TextBlock Classes="eyebrow" Text="{loc:Loc Section.Backups}" /></Expander.Header>
                        <StackPanel Spacing="12" Margin="2,4,2,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Classes="ghost" Content="{loc:Loc Backups.Refresh}"
                                        Command="{Binding RefreshCommand}" />
                                <Button Classes="ghost" Content="{loc:Loc Backups.OpenFolder}"
                                        Command="{Binding OpenBackupFolderCommand}" />
                                <Button Classes="primary" Content="{loc:Loc Backups.BackupNow}"
                                        Command="{Binding BackupNowCommand}"
                                        IsEnabled="{Binding !Busy}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="Auto,*" MinHeight="120" MaxHeight="340">
                                <Border Grid.Column="1" Background="{StaticResource InkBaseBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="2">
                                    <ListBox x:Name="SnapshotList"
                                             ItemsSource="{Binding Snapshots}"
                                             SelectedItem="{Binding SelectedSnapshot}"
                                             SelectionMode="Multiple"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:Snapshot">
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,5">
                                                    <Border Grid.Column="0" Width="7" CornerRadius="3"
                                                            Margin="0,1,12,1"
                                                            Background="{Binding Label, Converter={StaticResource LabelBrush}}" />
                                                    <StackPanel Grid.Column="1" Spacing="1">
                                                        <TextBlock Text="{Binding TakenAtDisplay}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="13" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SubLine}"
                                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <!-- save preview: shown only when a matching image exists -->
                                <Border Grid.Column="0" Width="200" Margin="0,0,10,0"
                                        VerticalAlignment="Top"
                                        IsVisible="{Binding HasPreviewImage}"
                                        Background="{StaticResource InkBaseBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="4">
                                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                                </Border>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Classes="ghost" Content="{loc:Loc Backups.OpenThis}"
                                        Command="{Binding OpenSnapshotFolderCommand}"
                                        IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <Button Classes="danger" Content="{loc:Loc Common.Delete}"
                                        Command="{Binding DeleteSnapshotsCommand}"
                                        CommandParameter="{Binding #SnapshotList.SelectedItems}"
                                        IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <Button Classes="primary" Content="{loc:Loc Backups.RestoreThis}"
                                        Command="{Binding RestoreSelectedCommand}"
                                        IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- empty state -->
            <StackPanel Grid.Row="0" IsVisible="{Binding !HasProfile}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="{loc:Loc Empty.Title}" FontSize="16"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Loc Empty.Subtitle}"
                           Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- status bar -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0"
                    Padding="20,9">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Status}" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                VerticalAlignment="Center" IsVisible="{Binding UpdateReady}">
                        <TextBlock Text="{Binding UpdateBannerText}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource GuardGoldBrush}" />
                        <Button Classes="primary" Padding="12,5" Content="{loc:Loc Update.Restart}"
                                Command="{Binding RestartToUpdateCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
